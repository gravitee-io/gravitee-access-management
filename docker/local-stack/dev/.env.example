# local-stack version / registry config (used by `local-stack.sh up --version`).
#
# Copy this file to `dev/.env` (gitignored) to persist your own defaults.
# CLI flags --version / --registry always override whatever is set here.

# Released image version + registry — safe public defaults (Docker Hub).
GIO_AM_VERSION=4
AM_REGISTRY=graviteeio

# For PRE-RELEASE / nightly tags (e.g. 4.13.x-latest, master-latest), copy this
# file to dev/.env, point AM_REGISTRY at your private Gravitee registry, and run
# `docker login <that registry>` first, e.g.:
#
#   GIO_AM_VERSION=4.13.x-latest
#   AM_REGISTRY=graviteeio.azurecr.io
#

# Optional database image version overrides:
# MONGO_VERSION=8.0
# POSTGRES_VERSION=17.2
