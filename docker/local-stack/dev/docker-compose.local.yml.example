#
# Per-developer overrides for the local stack. Copy to `docker-compose.local.yml`
# (gitignored) and local-stack.sh will merge it LAST on every `up`, so it wins over
# the tracked overlays. Works for BOTH source-built and pulled (--version) images.
#
#   cp dev/docker-compose.local.yml.example dev/docker-compose.local.yml
#   ./local-stack.sh up            # your overrides are applied automatically
#
# Two ways to customise gravitee.yml settings:
#
#  A) Environment variables (recommended — no rebuild, works on any image).
#     Any gravitee.yml key maps to GRAVITEE_<UPPER_SNAKE>, nested keys joined by "_",
#     list indices as numbers. Examples below.
#
#  B) Mount your own gravitee.yml over the baked one (whole-file replacement).
#
# Delete the services/keys you don't need.

services:
  management:
    environment:
      # - GRAVITEE_HTTP_API_AUTOMATION_ENABLED=true
    # volumes:
    #   - ./my-gravitee.yml:/opt/graviteeio-am-management-api/config/gravitee.yml:ro

  gateway:
    environment:
      # - GRAVITEE_HANDLERS_SCIM_INCLUDEERRORDETAILS=true
    # volumes:
    #   - ./my-gravitee.yml:/opt/graviteeio-am-gateway/config/gravitee.yml:ro
